{
  "name": "admin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:production": "NODE_ENV=production next build",
    "start": "next start",
    "start:production": "NODE_ENV=production next start -p ${PORT:-3000}",
    "worker:automation": "tsx src/workers/automation-worker.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typegen": "next typegen",
    "type-check": "next typegen && tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "db:generate": "pnpm prisma generate",
    "db:pull": "pnpm prisma db pull",
    "db:migrate": "pnpm prisma migrate deploy",
    "db:seed": "pnpm prisma db seed",
    "db:status": "pnpm prisma migrate status",
    "validate-startup": "node scripts/validate-startup.js",
    "docker:build": "docker build -t weekly-content-management .",
    "docker:run": "docker run -p 3000:3000 --env-file .env weekly-content-management",
    "health-check": "curl -f http://localhost:3000/api/health || exit 1"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
