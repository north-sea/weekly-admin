# 数据库配置 - nas服务器 (tailscale内网)
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# 数据库配置 (MySQL)
DATABASE_URL="mysql://username:password@host:port/database_name"

# JWT配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="8h"

# Meilisearch配置
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="your-meilisearch-master-key"

# 图片上传服务配置
IMAGE_UPLOAD_URL="https://img.mengpeng.tech/api/v1/upload"
IMAGE_UPLOAD_TOKEN="your-image-upload-token"

# Docker 部署配置
APP_VERSION=latest
APP_PORT=3000
DOCKER_REGISTRY=""
EXISTING_NETWORK_NAME="bridge"

# 生产环境配置
NODE_ENV=production
APP_VERSION=1.0.0
SERVICE_NAME=weekly-content-management

# 日志配置
LOG_LEVEL=info
# 可选值: error, warn, info, debug

# 监控配置
ENABLE_RESOURCE_MONITORING=true
RESOURCE_MONITORING_INTERVAL=30000
# 资源监控间隔（毫秒）

# 性能监控阈值
MEMORY_WARNING_THRESHOLD=80
MEMORY_CRITICAL_THRESHOLD=90
CPU_WARNING_THRESHOLD=80
CPU_CRITICAL_THRESHOLD=90

# Quail Newsletter 配置
# API 文档: https://docs.quaily.com/developer/
QUAIL_API_HOST="https://api.quail.ink"
QUAIL_API_KEY="your-quail-api-key"
QUAIL_CHANNEL_SLUG="your-channel-slug"
QUAIL_LIST_ID="your-list-id"

# AI（server-side；推荐用于批量/定时任务）
# 默认使用 OpenAI/兼容 API（chat/completions）
AI_PROVIDER="openai" # openai | anthropic
AI_BASE_URL="https://api.openai.com"
AI_API_KEY="your-api-key"
AI_TEXT_MODEL="gpt-4o-mini"

# 可选：如果 AI_PROVIDER=anthropic
ANTHROPIC_API_KEY="your-anthropic-api-key"
ANTHROPIC_MODEL="claude-3-5-sonnet-latest"
ANTHROPIC_BASE_URL="https://api.anthropic.com"
