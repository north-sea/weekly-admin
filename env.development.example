# Weekly内容管理系统 - 开发环境配置示例
# 复制此文件为 .env 用于本地开发

# =============================================================================
# 🗃️ 数据库配置 (必需)
# =============================================================================
# MySQL数据库连接字符串 - 连接到NAS服务器
DATABASE_URL="mysql://weekly_user:weekly_20250629_@NAS@100.113.231.101:3306/weekly_blog"

# =============================================================================
# 🔍 搜索引擎配置 (必需)
# =============================================================================
# Meilisearch 搜索引擎配置 - 连接到本地容器
# 确保 karakeep-meilisearch 容器正在运行
MEILISEARCH_HOST="http://localhost:7700"
MEILISEARCH_MASTER_KEY="your_meilisearch_master_key"

# =============================================================================
# 🔐 JWT认证配置 (必需)
# =============================================================================
# JWT密钥 - 用于用户认证令牌签名
JWT_SECRET="dev-jwt-secret-key-not-for-production"
# JWT令牌过期时间
JWT_EXPIRES_IN="24h"

# =============================================================================
# 🌐 开发环境配置
# =============================================================================
# 运行环境
NODE_ENV="development"

# 开发服务器端口
PORT="3000"

# =============================================================================
# 📝 开发环境说明
# =============================================================================
# 
# 本配置文件用于本地开发环境，特点：
# 
# 1. 数据库连接：
#    - 直接连接到NAS服务器的MySQL数据库
#    - 使用现有的weekly_blog数据库
#    - 无需本地运行MySQL
#
# 2. 搜索服务：
#    - 连接到本地运行的Meilisearch容器
#    - 容器名：karakeep-meilisearch
#    - 端口：7700
#
# 3. 开发特性：
#    - 热重载支持
#    - 详细的错误信息
#    - 开发工具支持
#
# 4. 启动步骤：
#    - 确保外部服务运行正常
#    - 运行: pnpm db:generate
#    - 运行: pnpm dev
#
# 5. 与生产环境区别：
#    - 不使用Docker容器
#    - JWT密钥仅用于开发
#    - 更长的Token过期时间
#    - 开发模式的详细日志