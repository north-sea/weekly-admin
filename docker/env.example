# Weekly内容管理系统 - Docker生产部署环境变量配置
# 复制此文件为 .env 并放在项目根目录，用于Docker生产部署

# =============================================================================
# 🗃️ 数据库配置 (必需)
# =============================================================================
# MySQL数据库连接字符串
# 注意: 当前配置连接到NAS服务器上的MySQL，不是本地Docker容器
# 如果要使用本地MySQL容器，格式为: mysql://user:password@mysql:3306/database
DATABASE_URL="mysql://weekly_user:weekly_20250629_@NAS@100.113.231.101:3306/weekly_blog"

# =============================================================================
# 🔍 搜索引擎配置 (必需)
# =============================================================================
# Meilisearch 搜索引擎配置
# 选项说明:
# 1. 容器名连接 (推荐): MEILISEARCH_HOST="http://karakeep-meilisearch:7700"
# 2. 主机端口连接: MEILISEARCH_HOST="http://host.docker.internal:7700"
# 3. 直接IP连接: MEILISEARCH_HOST="http://localhost:7700"
# 4. MEILISEARCH_MASTER_KEY generate with <openssl rand -base64 36 | tr -dc 'A-Za-z0-9'>
MEILISEARCH_HOST="http://karakeep-meilisearch:7700"
MEILISEARCH_MASTER_KEY="your_meilisearch_master_key"

# =============================================================================
# 🔐 JWT认证配置 (必需)
# =============================================================================
# JWT密钥 - 生产环境请使用复杂的随机字符串
JWT_SECRET="production-super-secret-jwt-key-please-change-this-immediately"
# JWT令牌过期时间
JWT_EXPIRES_IN="8h"

# =============================================================================
# 📚 Karakeep 草稿同步配置 (必需)
# =============================================================================
# Karakeep API 配置 - 用于同步书签到草稿管理
KARAKEEP_HOST="https://your-karakeep-instance.com"
KARAKEEP_KEY="your_karakeep_api_key"
KARAKEEP_DRAFT_LIST_ID="your_draft_list_id"

# =============================================================================
# 🐳 Docker部署配置 (必需)
# =============================================================================
# Docker Registry配置 - 镜像仓库地址
# 选项说明:
# 1. 私有Registry: DOCKER_REGISTRY="registry.nas.local:5000"
# 2. Docker Hub: DOCKER_REGISTRY="your-username"  
# 3. 本地镜像: DOCKER_REGISTRY=""
DOCKER_REGISTRY=""

# 应用版本号 - 对应Docker镜像的tag
# 部署时请修改为具体版本号，如: v1.2.3
APP_VERSION="latest"

# 应用端口映射 - 主机端口映射到容器3000端口
APP_PORT="3000"

# =============================================================================
# 🌐 应用环境配置
# =============================================================================
# 运行环境 - 生产部署固定为production
NODE_ENV="production"

# 容器内部端口 - 通常不需要修改
PORT="3000"

# =============================================================================
# 🔗 Docker Compose网络配置 (docker-compose.prod.yml专用)
# =============================================================================
# 外部网络名称 - 连接到现有Docker网络
# 默认使用bridge网络，如果有自定义网络请修改
EXISTING_NETWORK_NAME="bridge"

# =============================================================================
# 💡 Docker部署配置说明
# =============================================================================
# 
# 1. 网络连接方式：
#    - 本地开发: 直接连接 localhost:7700
#    - Docker部署: 推荐使用容器名 karakeep-meilisearch:7700
#    - 备选方案: host.docker.internal:7700 或 localhost:7700
#
# 2. 网络连接原理：
#    - 容器名连接: Docker自动解析容器名为IP地址
#    - 要求: 应用容器需要在相同网络或可访问的网络中
#    - 优势: 自动处理IP变化，更稳定
#
# 3. 常见部署场景：
#    
#    【场景1: 本地构建镜像部署】
#    DOCKER_REGISTRY=""
#    APP_VERSION="v1.0.0"
#    结果: weekly-content-management:v1.0.0
#    
#    【场景2: 私有Registry部署】
#    DOCKER_REGISTRY="registry.nas.local:5000"
#    APP_VERSION="v1.0.0"
#    结果: registry.nas.local:5000/weekly-content-management:v1.0.0
#    
#    【场景3: Docker Hub部署】
#    DOCKER_REGISTRY="your-username"
#    APP_VERSION="v1.0.0"
#    结果: your-username/weekly-content-management:v1.0.0
#
# 4. 部署步骤：
#    a) 复制此文件: cp docker/env.example .env
#    b) 编辑配置: vim .env
#    c) 构建镜像: ./scripts/build-and-push.sh v1.0.0
#    d) 部署服务: docker compose -f docker/docker-compose.prod.yml up -d
#
# 5. 安全建议：
#    - 生产环境必须修改JWT_SECRET为复杂密钥
#    - 不要将包含敏感信息的.env文件提交到git
#    - 定期轮换密钥和数据库密码
#    - 使用强密码和安全的网络配置
#
# 6. 故障排除：
#    - 容器无法连接Meilisearch: 
#      * 检查karakeep-meilisearch容器是否运行: docker ps | grep meilisearch
#      * 检查网络连通性: docker exec weekly-content-app ping karakeep-meilisearch
#      * 备选方案: 改用 host.docker.internal:7700 或 localhost:7700
#    - 镜像拉取失败: 检查DOCKER_REGISTRY和APP_VERSION配置
#    - 数据库连接失败: 确认DATABASE_URL和网络连通性
#    - 网络问题诊断:
#      * 查看容器网络: docker network ls
#      * 检查容器网络配置: docker inspect <container_name>