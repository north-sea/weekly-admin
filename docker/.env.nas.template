# Weekly Admin 环境变量模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 数据库配置 (必填)
# ============================================
DATABASE_URL=mysql://username:password@host:3306/database_name

# ============================================
# Meilisearch 配置 (必填)
# ============================================
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=your-meilisearch-api-key

# ============================================
# 认证配置 (必填)
# ============================================
# JWT 密钥 - 用于 API 认证
JWT_SECRET=your-jwt-secret-at-least-32-characters

# NextAuth 配置
NEXTAUTH_SECRET=your-nextauth-secret-at-least-32-characters
NEXTAUTH_URL=http://your-nas-ip:3000

# ============================================
# Cron Job API Token (可选)
# ============================================
# 用于定时任务调用 API
CRON_API_TOKEN=your-cron-api-token

# ============================================
# Quail Newsletter 配置 (可选)
# ============================================
# QUAIL_API_KEY=your-quail-api-key
# QUAIL_LIST_ID=your-quail-list-id

# ============================================
# 应用配置
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# 监控配置 (可选)
# ============================================
LOG_LEVEL=info
ENABLE_RESOURCE_MONITORING=true
MEMORY_WARNING_THRESHOLD=80
MEMORY_CRITICAL_THRESHOLD=90
